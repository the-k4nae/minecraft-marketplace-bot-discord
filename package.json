{
  "name": "discord-minecraft-bot",
  "version": "3.0.0",
  "description": "Bot de Discord para gerenciar tickets e anúncios de contas Minecraft",
  "keywords": [
    "discord",
    "bot",
    "minecraft",
    "marketplace"
  ],
  "license": "MIT",
  "author": "",
  "type": "module",
  "main": "index.js",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "postinstall": "npm rebuild better-sqlite3",
    "dev": "node --watch index.js",
    "start": "node index.js",
    "start:prod": "pm2 start ecosystem.config.cjs --env production",
    "stop": "pm2 stop bot-minecraft",
    "restart": "pm2 restart bot-minecraft",
    "logs": "pm2 logs bot-minecraft",
    "monit": "pm2 monit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@magicyan/discord": "^1.7.2",
    "@napi-rs/canvas": "^0.1.97",
    "better-sqlite3": "^12.6.2",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.0.0",
    "@vitest/ui": "^2.0.0",
    "pino-pretty": "^13.0.0",
    "vitest": "^2.0.0"
  },
  "vitest": {
    "environment": "node",
    "testMatch": [
      "tests/**/*.test.js"
    ],
    "coverage": {
      "provider": "v8",
      "reporter": [
        "text",
        "html"
      ],
      "include": [
        "utils/**/*.js",
        "handlers/**/*.js",
        "commands/**/*.js"
      ],
      "exclude": [
        "utils/db/core.js",
        "node_modules"
      ]
    }
  }
}