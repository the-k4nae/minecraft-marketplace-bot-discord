{
  "name": "discord-minecraft-bot",
  "version": "3.0.0",
  "description": "Bot de Discord para gerenciar tickets e anúncios de contas Minecraft (Components v2)",
  "keywords": [
    "discord",
    "bot",
    "minecraft",
    "tickets"
  ],
  "license": "MIT",
  "author": "",
  "type": "module",
  "main": "index.js",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "node --watch index.js",
    "start": "node index.js",
    "start:prod": "pm2 start ecosystem.config.cjs --env production",
    "stop": "pm2 stop bot-minecraft",
    "restart": "pm2 restart bot-minecraft",
    "logs": "pm2 logs bot-minecraft",
    "monit": "pm2 monit"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "discord.js": "^14.17.0",
    "dotenv": "^17.3.1",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2"
  }
}